Sub Nendo()

    Dim strSakunen As String
    Dim strKotoshi As String
    Dim strlist    As String
    
    strSakunen = Year(Me.txtNow) - 1
    strKotoshi = Year(Me.txtNow)
    strlist = strlist & strKotoshi & ";"
    strlist = strlist & strSakunen
    If Month(Me.txtNow) < 4 Then
        Me.cbo年度 = strSakunen
    ElseIf Month(Me.txtNow) > 4 Then
        Me.cbo年度 = strKotoshi
    Else
        Me.cbo年度.RowSource = strlist
        Me.cbo年度.DefaultValue = Me.cbo年度.ItemData(0)
    End If

End Sub

' ================================================================
' 受付年度：今年度か否かを判定し、次の番号を strNextBangou に格納する
'
' 修正点：
'   ① MAX(番号) の列別名を rs.Fields(0) でアクセスして 3265 を回避
'   ② Null対応（テーブルが空のとき）
'   ③ rs/cn を関数内で完全にクローズして呼び出し元に開放した状態で返す
'   ④ 次の番号を Public変数 strNextBangou に格納して呼び出し元に渡す
' ================================================================

Function 受付年度(strTable As String) As Boolean

    Dim strNen      As String
    Dim strNonen    As String
    Dim lngMax      As Long

    受付年度 = False
    strNextBangou = ""

    ' MAX(番号)取得
    Call CN_INIT(intSts)
    If intSts <> DB_OK Then Exit Function

    strSQL = "SELECT MAX(番号) FROM " & strTable   ' ★ AS 句を外す
    Call RS_INIT(intSts)
    If intSts <> DB_OK Then
        Call CN_END
        Exit Function
    End If

    rs.Open strSQL, cn, adOpenKeyset, adLockOptimistic

    ' ★ Fields(0) でアクセス（列別名に依存しない）
    If IsNull(rs.Fields(0).Value) Then
        ' テーブルが空 → 年度2ケタ * 10000 + 1 が最初の番号
        lngMax = 0
    Else
        lngMax = CLng(rs.Fields(0).Value)
    End If

    ' ★ rs/cn をここで完全クローズ（呼び出し元では rs を触らない）
    Call RS_END
    Call CN_END

    ' 年度判定
    strNonen = Right(CStr(Year(DateAdd("m", -3, Date))), 2)
    Me.txt年度2ケタ = strNonen

    If lngMax = 0 Then
        ' テーブル空 → 今年度の1番目
        strNextBangou = CStr(CLng(strNonen) * 10000 + 1)
        受付年度 = True
        Exit Function
    End If

    strNen = Left(CStr(lngMax), 2)   ' 登録済み最大番号の上2桁

    If strNen = strNonen Then
        ' 今年度
        strNextBangou = CStr(lngMax + 1)
        受付年度 = True
    Else
        ' 昨年度→今年度初番
        strNextBangou = CStr(CLng(strNonen) * 10000 + 1)
        受付年度 = False
    End If

End Function