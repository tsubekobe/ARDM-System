' ================================================================
'  新規追加：PW認証チェック関数
'
' 役割：
'   - flgPwOk が既に認証済みなら即 True を返す（セッション中は再入力不要）
'   - 所属部門に応じたパスワードを確認し、成功なら flgPwOk を更新して True
'   - 失敗 or キャンセルなら False
'
' 呼び出し元：cmd登録_Click、cmd編集_Click
' ================================================================
Private Function PW認証チェック(ByVal strAction As String) As Boolean

    PW認証チェック = False

    Dim strBumon As String
    Dim strInput As String
    Dim strPwJimu As String
    Dim strPwSys As String
    Dim intPwOk As Integer

    strBumon = Trim$(職員情報Key.所属部門)
    strPwJimu = 設定値取得("PW_JIMU", "")
    strPwSys = 設定値取得("PW_SYS", "")

    If strAction = "EDIT" Then
        intPwOk = flgPwOkEdit
    Else
        intPwOk = flgPwOkReg
    End If

    ' 所属部門が "3" 以下（一般職員）は編集権限なし
    If strBumon <= "3" Then
        MsgBox "編集・登録権限がありません。", vbExclamation, cstSys
        Exit Function
    End If

    ' ── この操作で既に認証済みならスキップ ─────────
    If strBumon >= "6" Then
        If intPwOk >= 2 Then
            PW認証チェック = True
            Exit Function
        End If
    ElseIf strBumon >= "4" Then
        If intPwOk >= 1 Then
            PW認証チェック = True
            Exit Function
        End If
    End If

    If strBumon >= "6" And strPwSys = "" Then
        MsgBox "システム管理パスワードが未設定です。" & vbCrLf & _
               "環境変数 UKAGAI_PW_SYS または Tシステム設定 を確認してください。", vbExclamation, cstSys
        Exit Function
    ElseIf strBumon >= "4" And strPwJimu = "" Then
        MsgBox "管理パスワードが未設定です。" & vbCrLf & _
               "環境変数 UKAGAI_PW_JIMU または Tシステム設定 を確認してください。", vbExclamation, cstSys
        Exit Function
    End If

    ' ── パスワード入力 ────────────────────
    strInput = InputBoxDK("編集・登録パスワードを入力してください", "認証")

    If strBumon >= "6" Then
        If strInput = strPwSys Then
            intPwOk = 2
            flgHyouji = 2
            flgSYS = 1
            PW認証チェック = True
        Else
            MsgBox cstMsg05, vbExclamation, cstSys
        End If
    ElseIf strBumon >= "4" Then
        If strInput = strPwJimu Then
            intPwOk = 1
            flgHyouji = 1
            PW認証チェック = True
        Else
            MsgBox cstMsg05, vbExclamation, cstSys
        End If
    End If

    If PW認証チェック = True Then
        If strAction = "EDIT" Then
            flgPwOkEdit = intPwOk
        Else
            flgPwOkReg = intPwOk
        End If
    End If

End Function