' ================================================================
' 修正版 cmd削除_Click（Fロック管理.frm）
' 問題: WHERE句で "企画番号" を使っているが正しくは "伺企番号"
' ================================================================
Private Sub cmd削除_Click()
On Error GoTo Err_cmd削除_Click

    Dim strKey As String

    strKey = Nz(Me.txt企画番号, "")
    If strKey = "" Then
        MsgBox "伺企番号が取得できません。", vbExclamation
        Exit Sub
    End If

    Call ロック_DEL_BY_KEY(strKey)
    Call データ削除("Tロック伺企", "伺企番号", strKey)

    Me.Requery

Exit_cmd削除_Click:
    Exit Sub

Err_cmd削除_Click:
    MsgBox Err.Description
    Resume Exit_cmd削除_Click
End Sub

Private Sub cmd戻る_Click()

    DoCmd.OpenForm "Fメニュー"
    DoCmd.Close acForm, "Fロック管理", acSaveNo

End Sub

Private Sub Form_Load()
    
'    Me.Caption = cstSysK
    Me.cmd削除.SetFocus

End Sub